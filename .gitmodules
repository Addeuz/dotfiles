[submodule ".config/zsh/custom/plugins/zsh-autosuggestions"]
	path = .config/zsh/custom/plugins/zsh-autosuggestions
	url = https://github.com/zsh-users/zsh-autosuggestions

[submodule ".config/zsh/custom/plugins/zsh-syntax-highlighting"]
	path = .config/zsh/custom/plugins/zsh-syntax-highlighting
	url = https://github.com/zsh-users/zsh-syntax-highlighting

[submodule ".config/zsh/custom/plugins/you-should-use"]
	path = .config/zsh/custom/plugins/you-should-use
	url = https://github.com/MichaelAquilina/zsh-you-should-use

[submodule ".config/zsh/custom/themes/powerlevel10k"]
	path = .config/zsh/custom/themes/powerlevel10k
	url = https://github.com/romkatv/powerlevel10k

[submodule ".tmux/plugins/tmux-sensible"]
	path = .tmux/plugins/tmux-sensible
	url = https://github.com/tmux-plugins/tmux-sensible

[submodule ".tmux/plugins/tokyo-night-tmux"]
	path = .tmux/plugins/tokyo-night-tmux
	url = https://github.com/janoamaral/tokyo-night-tmux

[submodule ".tmux/plugins/tpm"]
	path = .tmux/plugins/tpm
	url = https://github.com/tmux-plugins/tpm

[submodule ".claude/plugins/marketplaces/svelte"]
	path = .claude/plugins/marketplaces/svelte
	url = https://github.com/sveltejs/ai-tools
